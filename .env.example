APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# لوحة Filament تُجبر locale على ar أثناء التشغيل (AppServiceProvider + Filament::serving).

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# بادئة رقم السجل التلقائي للمرضى (مثال: ISN → ISN-00000001). اختياري.
# ISNAD_REGISTRY_PREFIX=ISN
# ISNAD_REGISTRY_SEQUENCE_LENGTH=8
# مدة جلسة عرض الملف بعد التحقق من رقم السجل (بالدقائق).
# ISNAD_REGISTRY_LOOKUP_TTL=15

# أدوار المستخدمين في عمود users.role: admin | patient
#
# ملخص AI (OpenAI): يتطلب OPENAI_API_KEY و ISNAD_AI_SUMMARY_ENABLED=true
# ISNAD_AI_SUMMARY_ENABLED=false
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# مسار tesseract.exe — على Windows: ضع المسار بين "..." واستخدم / بدل \ (مثال)، أو استخدم \\ مضاعفاً إن احتجت \.
# TESSERACT_BINARY="C:/Program Files/Tesseract-OCR/tesseract.exe"
# استخراج كيانات من OCR عبر نفس مفتاح OpenAI (اختياري):
# ISNAD_DOCUMENT_EXTRACTION_ENABLED=false

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# الطابور (معالجة المرفقات: OCR، النسخة المحسّنة، استخراج الكيانات…):
# - database = يحتاج عاملاً مستمراً: `php artisan queue:work` أو ضمن `composer dev` يعمل `queue:listen`.
# - sync = تنفيذ فوري داخل نفس الطلب (بسيط للتطويل؛ تجنّبه إذا كانت المعالجة ثقيلة وتسبب مهلة HTTP).
QUEUE_CONNECTION=database

# إذا true + تشغيل الجدولة كل دقيقة (`php artisan schedule:run`): يُفرَّغ الطابور تلقائياً دون إبقاء terminal مفتوحاً.
# على Windows: مجدول المهام يستدعي schedule:run كل دقيقة من مجلد المشروع.
ISNAD_QUEUE_PROCESS_VIA_SCHEDULER=false

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
